    "Issuer": "https://api.arzamart.com",
    "Audience": "https://arzamart.com"
  },
  "Auth": {
    "CookieDomain": ".arzamart.com"
  },
  "AllowedOrigins": [
    "http://localhost:4200",
    "https://localhost:4200",
